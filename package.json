{
  "name": "emora-agent",
  "version": "1.2.0",
  "description": "EMORA — Autonomous AI Agent. Self-hosted, multi-platform, multi-provider.",
  "type": "module",
  "main": "main.js",
  "bin": {
    "emora": "./bin/emora.js"
  },
  "scripts": {
    "start": "node main.js",
    "setup": "node setup.js",
    "status": "node bin/emora.js status",
    "postinstall": "chmod +x bin/emora.js 2>/dev/null || true",
    "webui:install": "npm install --prefix webui",
    "webui:dev": "npm run dev --prefix webui",
    "webui:build": "npm run build --prefix webui"
  },
  "keywords": [
    "ai",
    "agent",
    "telegram",
    "whatsapp",
    "langchain",
    "autonomous"
  ],
  "author": "arthurlucky",
  "license": "MIT",
  "dependencies": {
   "@whiskeysockets/baileys": "^7.0.0-rc13",
    "pino": "^8.14.1",
    "@hapi/boom": "^10.0.1",
    "@langchain/core": "^1.2.1",
    "@langchain/openai": "^1.5.3",
    "adm-zip": "^0.5.16",
    "archiver": "^7.0.1",
    "axios": "^1.9.0",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "fast-glob": "^3.3.3",
    "figlet": "^1.8.0",
    "langchain": "^1.5.2",
    "multer": "^2.0.1",
    "node-cron": "^3.0.3",
    "node-html-parser": "^7.0.1",
    "ora": "^8.2.0",
    "telegraf": "^4.16.3",
    "zod": "^3.24.2"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
